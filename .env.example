# ==========================================
# FRONTEND ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Copy this file to .env.local and fill in the actual values
# Do not commit .env.local to version control

# ==========================================
# API CONFIGURATION
# ==========================================
# Base URL for the backend API
# For local development: http://localhost:3000
# For production: https://your-backend-api.com
#VITE_API_URL=http://localhost:3000
const API_URL = import.meta.env.VITE_API_URL || "http://localhost:3000";
# ==========================================
# AUTHENTICATION CONFIGURATION
# ==========================================
# Google OAuth Client ID (if using Google Sign-In)
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# JWT Secret (for token validation - should match backend)
VITE_JWT_SECRET=your-jwt-secret

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Application name
VITE_APP_NAME=LocalHands

# Currency configuration
VITE_DEFAULT_CURRENCY=XAF
VITE_CURRENCY_SYMBOL=FCFA

# ==========================================
# PAYMENT CONFIGURATION
# ==========================================
# Fabshi Payment Gateway Configuration
VITE_FABSHI_API_URL=https://api.fabshi.com
VITE_FABSHI_PUBLIC_KEY=your-fabshi-public-key

# ==========================================
# FEATURE FLAGS
# ==========================================
# Enable/disable features
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_PAYMENTS=true

# ==========================================
# ENVIRONMENT
# ==========================================
# Environment: development, staging, production
NODE_ENV=development
